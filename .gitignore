.gradle-local/

# Local debug/log artifacts
1.txt
# Python dev tool output (regenerated by tools/analyze_students*.py)
students_rendered.html

# Kotlin compilation cache (per-machine, never commit)
.kotlin/

# Local development scratch files (not part of the build, broken references)
fallback.kt
wiki_gif.bin
sticker_fallback.json

# Python bytecode cache (regenerated automatically)
__pycache__/
*.pyc
*.pyo

# Local Python debug scripts (one-off inspections, not part of the repo)
_inspect.py

# Local UI design exploration (HTML mockups / Figma files / design notes, not project source)
UI_work/

# Platform-specific prebuilt binaries (use system-installed oxipng or download on demand)
scripts/oxipng-*-*/

# Trae IDE workbuddy extension local memory (per-user agent state, not project source)
.workbuddy/
